# OpenRouter credential. Keep the real value only in your ignored .env file.
# This non-secret placeholder allows deterministic preview and config-check.
# Replace it only when you intentionally choose live execution.
OPENROUTER_API_KEY=replace-me-before-live-use
FORGE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Assign any OpenRouter model identifier to each role.
# Every role model must reliably return JSON that matches a provided schema
# ("structured outputs"). Free-tier models often fail that contract and burn
# the call budget on retries. Verify current names and prices at
# https://openrouter.ai/models — dependable low-cost choices as of mid-2026
# include openai/gpt-4o-mini, google/gemini-2.5-flash-lite, and
# deepseek/deepseek-chat.
FORGE_MODEL_LEAD=replace/me
FORGE_MODEL_RESEARCHER=replace/me
FORGE_MODEL_CONNECTION_FINDER=replace/me
FORGE_MODEL_SYNTHESIZER=replace/me
FORGE_MODEL_SKEPTIC=replace/me
FORGE_MODEL_EXPERIMENT_DESIGNER=replace/me

# Local runtime behavior.
FORGE_DEFAULT_DEPTH=standard
FORGE_DATA_DIR=./data
FORGE_OUTPUT_DIR=./outputs
FORGE_LOG_DIR=./logs

# Approved cost-control defaults.
FORGE_QUICK_MAX_CALLS=8
FORGE_STANDARD_MAX_CALLS=10
FORGE_DEEP_MAX_CALLS=24
FORGE_QUICK_MAX_OUTPUT_TOKENS_PER_CALL=2400
FORGE_STANDARD_MAX_OUTPUT_TOKENS_PER_CALL=2400
FORGE_DEEP_MAX_OUTPUT_TOKENS_PER_CALL=4800
